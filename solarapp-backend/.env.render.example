# Render production environment variables (minimum required)
NODE_ENV=production
PORT=10000

# Database (TiDB/MySQL)
DB_HOST=your-tidb-host
DB_PORT=4000
DB_NAME=solar_app
DB_USER=your-db-user
DB_PASSWORD=your-db-password
DB_SSL=true
DB_SSL_REJECT_UNAUTHORIZED=true

# Security
JWT_SECRET=replace-with-a-long-random-string-min-64-chars
JWT_EXPIRE=24h
REFRESH_TOKEN_EXPIRE=7d

# CORS (comma-separated)
# Add your web URL and local dev URL
ALLOWED_ORIGINS=https://your-web-app.vercel.app,http://localhost:5173

# Optional app links
API_URL=https://your-backend-url.onrender.com/api
WEB_URL=https://your-web-app.vercel.app

# Optional: keep non-critical integrations disabled initially
ENABLE_2FA=false
ENABLE_VIRUS_SCAN=false
ENABLE_APM=false
SENTRY_DSN=
