# ============================================
# SolarApp Backend Configuration
# ============================================

# Server Configuration
NODE_ENV=development
PORT=5000
API_URL=http://localhost:5000/api
WEB_URL=http://localhost:3000

# ============================================
# Database Configuration
# ============================================
DB_HOST=localhost
DB_PORT=3306
DB_NAME=solar_app
DB_USER=solar_user
DB_PASSWORD=solar_pass123
DB_ROOT_PASSWORD=root123

# ============================================
# Security Configuration
# ============================================
JWT_SECRET=your-super-secret-jwt-key-change-in-production-min-64-chars
JWT_EXPIRE=24h
REFRESH_TOKEN_EXPIRE=7d
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,https://yourdomain.com

# ============================================
# Email Service Configuration
# ============================================
# Options: nodemailer, sendgrid, aws-ses
EMAIL_PROVIDER=nodemailer

# Nodemailer (SMTP)
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=your_mailtrap_user
SMTP_PASS=your_mailtrap_password
SMTP_FROM=noreply@solarapp.com

# SendGrid
SENDGRID_API_KEY=your_sendgrid_api_key
SENDGRID_FROM_EMAIL=noreply@solarapp.com

# AWS SES
AWS_SES_FROM_EMAIL=noreply@solarapp.com

# ============================================
# SMS Service Configuration
# ============================================
# Options: twilio, aws-sns, exotel, development
SMS_PROVIDER=twilio

# Twilio
TWILIO_ACCOUNT_SID=your_account_sid
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# Exotel (India)
EXOTEL_API_KEY=your_api_key
EXOTEL_API_TOKEN=your_api_token
EXOTEL_SENDER_ID=SOLARAPP

# ============================================
# File Upload Configuration
# ============================================
# Options: local, s3, gcs, azure
STORAGE_PROVIDER=local
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760

# AWS S3
AWS_ACCESS_KEY=your_access_key
AWS_SECRET_KEY=your_secret_key
AWS_REGION=us-east-1
AWS_S3_BUCKET=solarapp-files

# Google Cloud Storage
GCS_PROJECT_ID=your_project_id
GCS_KEY_FILE=./gcs-key.json
GCS_BUCKET=solarapp-files

# Azure Blob Storage
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...
AZURE_CONTAINER_NAME=solarapp-files

# ============================================
# Redis Configuration (Caching & Sessions)
# ============================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_TTL=86400

# ============================================
# Payment Gateway Configuration
# ============================================
# Razorpay
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret

# ============================================
# Two-Factor Authentication
# ============================================
ENABLE_2FA=true
TOTP_WINDOW=2
OTP_EXPIRY=600

# ============================================
# Firebase (Push Notifications - Mobile)
# ============================================
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_PRIVATE_KEY_ID=your_private_key_id
FIREBASE_PRIVATE_KEY=your_private_key
FIREBASE_CLIENT_EMAIL=your_client_email
FIREBASE_CLIENT_ID=your_client_id
FIREBASE_AUTH_URI=https://accounts.google.com/o/oauth2/auth
FIREBASE_TOKEN_URI=https://oauth2.googleapis.com/token

# ============================================
# Virus Scanning (ClamAV)
# ============================================
ENABLE_VIRUS_SCAN=false
CLAMAV_HOST=localhost
CLAMAV_PORT=3310

# ============================================
# Error Tracking (Sentry)
# ============================================
SENTRY_DSN=https://your_sentry_dsn@sentry.io/project_id
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=1.0

# ============================================
# Monitoring & Analytics
# ============================================
ENABLE_APM=false
DATADOG_API_KEY=your_datadog_key
LOG_LEVEL=info

# ============================================
# Secrets Management
# ============================================
# Options: local (development), aws-secrets-manager, vault
SECRETS_PROVIDER=local

# ============================================
# Feature Flags
# ============================================
FEATURE_EMAIL_NOTIFICATIONS=true
FEATURE_SMS_NOTIFICATIONS=true
FEATURE_PUSH_NOTIFICATIONS=true
FEATURE_PAYMENTS=true
FEATURE_REAL_TIME_CHAT=true
FEATURE_GPS_TRACKING=true

# ============================================
# Compliance & Security
# ============================================
ENABLE_HTTPS=false
SSL_CERT_PATH=/path/to/cert.pem
SSL_KEY_PATH=/path/to/key.pem
ENFORCE_HTTPS_REDIRECT=false

# ============================================
# Development Only
# ============================================
DEBUG=false
LOG_SQL_QUERIES=false
